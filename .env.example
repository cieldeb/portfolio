# Copy this file to .env (gitignored) and fill in what you have.
# Both are optional — the build works without them, just with lower rate
# limits and no Cults3D download counts. See _plugins/remote_git_stats.rb.

# GitHub personal access token, no special scopes needed. Raises the API
# rate limit used for commit counts / PR status from 60 to 5000 requests/hour.
GITHUB_TOKEN=

# Cults3D account nick + API key (generate one from your account's API
# settings on cults3d.com) — needed for download counts on Cults3D-linked
# projects, Cults3D has no unauthenticated read access at all.
CULTS_USERNAME=
CULTS_API_KEY=
